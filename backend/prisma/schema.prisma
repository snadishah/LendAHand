generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Postgres does support native enums, but these fields were originally written
// for SQLite (no enum support) and are still validated as plain strings by Zod
// at the API boundary, so they're kept as strings for continuity. Allowed values:
// Strings validated by Zod at the API boundary. Allowed values:
//   User.userType         "POSTER" | "HELPER"
//   Task.status            "OPEN" | "IN_PROGRESS" | "SUBMITTED" | "DONE" | "CANCELLED" | "DISPUTED"
//   Bid.status              "PENDING" | "ACCEPTED" | "REJECTED"
//   WalletTransaction.type "DEPOSIT" | "WITHDRAW" | "ESCROW_HOLD" | "ESCROW_RELEASE" | "REFUND"
//   Dispute.status         "OPEN" | "RESOLVED"
//   Dispute.resolution     "RELEASED" | "REFUNDED"

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  passwordHash  String
  userType      String
  city          String?
  phone         String?
  walletBalance Float    @default(0)
  isAdmin       Boolean  @default(false)
  isBanned      Boolean  @default(false)
  createdAt     DateTime @default(now())

  tasksPosted      Task[]              @relation("PosterTasks")
  tasksHelping     Task[]              @relation("HelperTasks")
  bids             Bid[]
  reviewsWritten   Review[]            @relation("ReviewsWritten")
  reviewsReceived  Review[]            @relation("ReviewsReceived")
  walletTxs        WalletTransaction[]
  notifications    Notification[]
  contactShares    ContactShare[]
  disputesRaised   Dispute[]           @relation("DisputesRaised")
  disputesResolved Dispute[]           @relation("DisputesResolved")
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  icon  String @default("📋")
  tasks Task[]
}

model Task {
  id             Int      @id @default(autoincrement())
  posterId       Int
  poster         User     @relation("PosterTasks", fields: [posterId], references: [id])
  categoryId     Int
  category       Category @relation(fields: [categoryId], references: [id])
  title          String
  description    String
  address        String
  latitude       Float?
  longitude      Float?
  budget         Float
  status         String   @default("OPEN")
  helperId       Int?
  helper         User?    @relation("HelperTasks", fields: [helperId], references: [id])
  acceptedAmount Float?
  submittedAt    DateTime?
  createdAt      DateTime @default(now())

  bids          Bid[]
  reviews       Review[]
  contactShares ContactShare[]
  disputes      Dispute[]

  @@index([status])
  @@index([posterId])
  @@index([helperId])
}

model Dispute {
  id           Int       @id @default(autoincrement())
  taskId       Int
  task         Task      @relation(fields: [taskId], references: [id])
  raisedById   Int
  raisedBy     User      @relation("DisputesRaised", fields: [raisedById], references: [id])
  reason       String
  status       String    @default("OPEN")
  resolution   String?
  note         String?
  resolvedById Int?
  resolvedBy   User?     @relation("DisputesResolved", fields: [resolvedById], references: [id])
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?

  @@index([status])
  @@index([taskId])
}

model Bid {
  id             Int      @id @default(autoincrement())
  taskId         Int
  task           Task     @relation(fields: [taskId], references: [id])
  helperId       Int
  helper         User     @relation(fields: [helperId], references: [id])
  proposedAmount Float
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())

  @@unique([taskId, helperId])
  @@index([taskId])
  @@index([helperId])
}

model Review {
  id         Int      @id @default(autoincrement())
  taskId     Int
  task       Task     @relation(fields: [taskId], references: [id])
  reviewerId Int
  reviewer   User     @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  revieweeId Int
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([taskId, reviewerId])
  @@index([revieweeId])
}

model WalletTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model ContactShare {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
  @@index([taskId])
}
